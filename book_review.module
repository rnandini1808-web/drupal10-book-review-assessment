<?php

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_theme().
 */
function book_review_theme($existing, $type, $theme, $path) {
  return [
    'book_review_listing' => [
      'variables' => [
        'reviews' => [],
      ],
      'template' => 'book-review-listing',
    ],
    'book_review_card' => [
      'variables' => [
        'review' => NULL,
      ],
      'template' => 'book-review-card',
    ],
  ];
}

/**
 * Implements hook_entity_view_alter().
 */
function book_review_entity_view_alter(array &$build, EntityInterface $entity, $display) {

  if ($entity->getEntityTypeId() !== 'node' || $entity->bundle() !== 'book_review') {
    return;
  }

  if (!$entity->hasField('field_star_rating')) {
    return;
  }

  $rating = (int) $entity->get('field_star_rating')->value;

  $build['#attributes']['class'][] = match (TRUE) {
    $rating >= 4 => 'book-review--high',
    $rating <= 2 => 'book-review--low',
    default => 'book-review--medium',
  };
}

/**
 * Implements hook_preprocess_book_review_listing().
 */
function book_review_preprocess_book_review_listing(&$variables) {
  $variables['#attached']['library'][] = 'book_review/book_review_styles';
}