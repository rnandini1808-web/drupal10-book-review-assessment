<div class="book-review-card">

  <div class="book-review-image">
    {% if review.image %}
      <img src="{{ review.image }}" alt="{{ review.title }}">
    {% endif %}
  </div>

  <div class="book-review-content">

    <h3>{{ review.title }}</h3>

    <div class="book-review-author">
      {{ review.author }}
    </div>

    <div class="book-review-rating">
      {% for i in 1..5 %}
        {% if i <= review.rating %}
          ★
        {% else %}
          ☆
        {% endif %}
      {% endfor %}
    </div>

    <div class="book-review-body">
      {{ review.body|striptags|slice(0, 120) }}...
    </div>

    <div class="book-review-read-more">
      <a href="{{ review.url }}">Read More</a>
    </div>

  </div>

</div>